{
  "version": 1,
  "servers": {
    "git": {
      "type": "local",
      "command": "uvx",
      "args": [
        "--from",
        "mcp-server-git==2026.1.14",
        "mcp-server-git",
        "--repository",
        "${PROJECT_ROOT}"
      ],
      "env": {
        "GIT_CONFIG_GLOBAL": "/dev/null"
      },
      "disabled": false,
      "autoApprove": ["*"]
    },
    "filesystem": {
      "type": "local",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-filesystem@2026.1.14",
        "${PROJECT_ROOT}"
      ],
      "disabled": false,
      "autoApprove": ["read_file", "list_directory", "list_files"]
    },
    "neon": {
      "type": "local",
      "command": "bun",
      "args": [
        "run",
        "node_modules/@neondatabase/mcp-server-neon/dist/index.js",
        "start",
        "${NEON_API_KEY}"
      ],
      "disabled": false,
      "autoApprove": ["*"]
    },
    "postgres": {
      "type": "local",
      "command": "bunx",
      "args": [
        "@modelcontextprotocol/server-postgres@0.6.2",
        "postgresql://localhost:5432/YOUR_DB_NAME"
      ],
      "disabled": false,
      "autoApprove": ["query", "describe", "list_tables", "list_columns"]
    }
  }
}
